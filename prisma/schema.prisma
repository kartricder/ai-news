// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Article {
  id                   String   @id @default(cuid())
  title                String
  slug                 String   @unique
  summaryVi            String
  contentVi            String   @default("")
  sourceName           String
  sourceUrl            String
  originalUrl          String
  originalTitle        String   @default("")
  originalPublishedAt  DateTime?
  fetchedAt            DateTime @default(now())
  publishedAt          DateTime?
  category             String   @default("general")
  tags                 String   @default("")
  importanceScore      Int      @default(0)
  reasonForScore       String   @default("")
  status               String   @default("draft") // draft, pending, published, rejected
  telegramSent         Boolean  @default(false)
  contentHash          String   @default("")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([status])
  @@index([importanceScore])
  @@index([sourceName])
  @@index([sourceUrl])
  @@index([originalUrl])
  @@index([contentHash])
  @@index([createdAt])
  @@index([slug])
}

model Source {
  id         String   @id @default(cuid())
  name       String   @unique
  type       String   // rss, api, github, reddit, hackernews, facebook, custom
  url        String
  enabled    Boolean  @default(true)
  configJson String   @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CrawlRun {
  id              String    @id @default(cuid())
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  status          String    @default("running") // running, completed, failed
  totalFetched    Int       @default(0)
  totalPublished  Int       @default(0)
  totalRejected   Int       @default(0)
  totalPending    Int       @default(0)
  errorMessage    String    @default("")
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  encrypted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TelegramLog {
  id             String    @id @default(cuid())
  articleId      String
  chatIdMasked   String    @default("")
  status         String    @default("pending") // pending, sent, failed
  errorMessage   String    @default("")
  sentAt         DateTime?
  createdAt      DateTime  @default(now())
}
